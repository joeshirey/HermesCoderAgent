# hermes-coder — environment (example)
#
# Copy to .env and fill in your own values. NEVER commit a real .env.
# Secrets are read from the environment, not from config.sample.yaml.
#
# The live coordinator runs inside a larger host agent that owns the
# messaging transport (e.g. Telegram). Adopting just the coding
# coordinator does not require the transport keys — include only what your
# host agent actually uses.

# --- LLM provider (used by the active coding harness and support passes) ---
GOOGLE_API_KEY=your-google-api-key-here

# --- Messaging transport (optional; only if your host agent uses Telegram) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=your-numeric-user-id-here
TELEGRAM_HOME_CHANNEL=your-home-chat-id-here
TELEGRAM_HOME_CHANNEL_THREAD_ID=your-thread-id-here

# --- GitHub ---
# Do NOT put a PAT here. Authenticate with `gh auth login` (or an SSH key) so
# the github_lifecycle / github_backlog scripts inherit credentials from gh.
